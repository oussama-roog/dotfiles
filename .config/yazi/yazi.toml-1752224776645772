[manager]
show_hidden = true
linemode = "size"

[open]
rules = [
    { mime = "image/*", use = "view_image" },
    { mime = "text/*", use = "edit" },
    { mime = "inode/directory", use = "change_dir" },  # Directory rule
    { mime = "application/pdf", use = "view_pdf" },
    { name = "*.zip", use = "extract_zip" },
    { name = "*.rar", use = "extract_rar" },
    { name = "*", use = "edit" }  # Fallback rule
]

[opener]
edit = [
    { run = 'nvim "$@"', block = true, for = "unix" },
]
view_image = [
    { run = 'loope "$@"', orphan = true, for = "unix" }
]
change_dir = [
    { run = 'cd "$@" && exec bash', block = true, for = "unix" }
]
view_pdf = [
    { run = 'xdg-open "$@"', orphan = true, for = "unix" }
]
extract_zip = [
    { run = 'unzip "$@"', desc = "Extract here", for = "unix" },
    { run = 'unzip "$@" -d "${1%.*}"', desc = "Extract in folder", for = "unix" }
]
extract_rar = [
    { run = 'unrar x "$@"', desc = "Extract here", for = "unix" },
    { run = 'unrar x "$@" "${1%.*}/"', desc = "Extract in folder", for = "unix" }
]
