[global]
    frame_color = "#e78a53"
[urgency_low]
    background = "#000000"
    foreground = "#c1c1c1"
    frame_color = "#333333"
    timeout = 5
    icon = dialog-information

[urgency_normal]
    background = "#000000"
    foreground = "#c1c1c1"
    frame_color = "#e78a53"
    timeout = 10
    icon = dialog-information

[urgency_critical]
    background = "#5f8787"
    foreground = "#c1c1c1"
    frame_color = "#5f8787"
    timeout = 0
    icon = dialog-error
