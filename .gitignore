# Ignore backup files
*.bak
*.backup

# Ignore log files
*.log

# Ignore the entire nvim undo directory
.config/nvim/undo/

# Ignore specific config files or directories
.config/kitty/*.bak
.config/kitty/tmux-client-*.log
.config/kitty/tmux-server-*.log

# Ignore all configuration files in the config directory
.config/hypr/hyprland.conf.bak

# Ignore all other potentially sensitive or unnecessary files
.config/*/*.bak
.config/*/*.log

# NixOS result symlinks
result
result-*

# Home-manager result symlinks
home-manager-result

# Theme-generated files (regenerated by theme-restore.sh)
.config/hypr/colors.conf
.config/waybar/colors.css
.config/rofi/colors.rasi
.config/kitty/colors.conf
.config/ghostty/config
.config/dunst/dunstrc
.config/yazi/theme.toml
.config/gtk-3.0/gtk.css
.config/gtk-4.0/gtk.css
home/oussama/colors.nix
