//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  // Global workspace bindings
  {
    "context": "Workspace",
    "bindings": {
      // File operations (leader + f)
      "space space": "file_finder::Toggle",
      "space f f": "file_finder::Toggle",
      "space f g": "project_search::ToggleFilters",
      "space f b": "tab_switcher::Toggle",
      "space f z": "workspace::NewSearch",

      // Project/workspace operations
      "space e": "workspace::ToggleLeftDock",
      "space f p": "projects::OpenRecent",

      // Window/split management (leader + s)
      "space s v": "pane::SplitRight",
      "space s h": "pane::SplitDown",
      "space s x": "pane::CloseActiveItem",

      // Buffers/tabs
      "space b d": "pane::CloseActiveItem"
    }
  },

  // Editor-specific bindings (general editor bindings)
  {
    "context": "Editor && vim_mode != insert",
    "bindings": {
      // Navigation improvements
      "shift-h": "editor::MoveToBeginningOfLine",
      "shift-l": "editor::MoveToEndOfLine",

      // Clear search highlights (leader + n + h)
      "space n h": "editor::Cancel",

      // System clipboard operations (leader + y/p)
      "space y": "editor::Copy",
      "space p": "editor::Paste",

      // LSP operations
      "space c a": "editor::ToggleCodeActions",
      "space r n": "editor::Rename",
      "space x x": "diagnostics::Deploy",

      // Go to definition/references (matching Neovim g* keys)
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDeclaration",
      "g r": "editor::FindAllReferences",
      "g I": "editor::GoToImplementation",
      "g y": "editor::GoToTypeDefinition",

      // Diagnostics navigation
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPrevDiagnostic",

      // Format code (leader + m + p)
      "space m p": "editor::Format",

      // Line manipulation
      "alt-k": "editor::MoveLineUp",
      "alt-j": "editor::MoveLineDown",

      "space ctrl-h": "workspace::ActivatePaneLeft",
      "space ctrl-l": "workspace::ActivatePaneRight"
    }
  },

  // Vim insert mode specific bindings
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {
      // Exit insert mode with jj
      "j j": ["workspace::SendKeystrokes", "escape"]
    }
  },

  // Vim normal mode specific bindings
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // Delete without yanking (similar to Neovim's x)
      "x": "editor::Delete"
    }
  },

  // File finder context
  {
    "context": "FileFinder",
    "bindings": {
      "ctrl-j": "menu::SelectNext",
      "ctrl-k": "menu::SelectPrev"
    }
  },

  // Command palette
  {
    "context": "CommandPalette",
    "bindings": {
      "ctrl-j": "menu::SelectNext",
      "ctrl-k": "menu::SelectPrev"
    }
  },

  // Project search
  {
    "context": "ProjectSearchBar",
    "bindings": {
      "ctrl-j": "search::NextHistoryQuery",
      "ctrl-k": "search::PreviousHistoryQuery"
    }
  },

  // Buffer search
  {
    "context": "BufferSearchBar",
    "bindings": {
      "ctrl-j": "search::NextHistoryQuery",
      "ctrl-k": "search::PreviousHistoryQuery"
    }
  },

  // Vim-style navigation in menus
  {
    "context": "Menu",
    "bindings": {
      "ctrl-j": "menu::SelectNext",
      "ctrl-k": "menu::SelectPrev",
      "ctrl-d": "menu::SelectNext",
      "ctrl-u": "menu::SelectPrev"
    }
  },

  // Disable certain global workspace bindings in Vim insert mode
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "space space": null,
      "space f f": null,
      "space f g": null,
      "space f b": null,
      "space f z": null,
      "space e": null,
      "space f p": null,
      "space s v": null,
      "space s h": null,
      "space s x": null,
      "space b d": null
    }
  }
]
