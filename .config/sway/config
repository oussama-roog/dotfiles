### Sway Config Equivalent ###

# Set mod key
set $mod Mod4

# Programs
set $terminal ghostty

# Floating modifier
floating_modifier $mod normal

# Output (Monitor)
output * bg ~/.config/hypr/wall.png fill

# Input (Keyboard/Touchpad)
input "type:keyboard" {
    xkb_layout us
    xkb_options ctrl:nocaps
}

input "type:touchpad" {
    tap enabled           # Enables tap-to-click
    tap_button_map lrm    # Maps single-finger tap to left-click, two-finger tap to right-click
    natural_scroll enabled # Optional: Enables natural scrolling
    dwt enabled           # Disables touchpad while typing
}

bindgesture swipe:right workspace prev   # Swipe right with three fingers to go to the previous workspace
bindgesture swipe:left workspace next    # Swipe left with three fingers to go to the next workspace

# Gaps and Borders
gaps inner 2
gaps outer 5
default_border pixel 2
default_floating_border pixel 2

# Colors (using values from Hyprland config)
client.focused #33ccffee #33ccffee #ffffff #33ccffee #33ccffee
client.unfocused #595959aa #595959aa #ffffff #595959aa #595959aa

# Keybindings

## Basics
bindsym $mod+t exec $terminal
bindsym $mod+q kill
bindsym $mod+shift+e exec "swaymsg exit"

# Reload the configuration file
bindsym $mod+Shift+c reload

# Launcher and scripts
bindsym $mod+space exec ~/.config/rofi/launcher/launcher.sh
bindsym $mod+p exec ~/.config/rofi/powermenu/powermenu.sh
bindsym Print exec ~/.config/rofi/applets/bin/screenshot.sh
bindsym $mod+v exec ~/.config/rofi/launcher/clipmanager.sh
bindsym $mod+c exec ~/.config/rofi/launcher/calc.sh

# Move focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Workspaces
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9
bindsym $mod+0 workspace 10

# Move windows to workspace
bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9
bindsym $mod+Shift+0 move container to workspace 10

# Move workspaces between outputs
bindsym $mod+Alt+h move workspace to output left
bindsym $mod+Alt+l move workspace to output right

# Scratchpad (Magic workspace equivalent)
bindsym $mod+s scratchpad show
bindsym $mod+Shift+s move scratchpad

# Floating window
bindsym $mod+Shift+space floating toggle
bindsym $mod+f floating toggle

# Layout
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Split horizontally/vertically
bindsym $mod+minus splith
bindsym $mod+bar splitv

# Resize windows with mouse
mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

    # Return to normal mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Audio and Media Keys
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioStop exec playerctl stop
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

# Autostart
exec_always --no-startup-id waybar
exec_always --no-startup-id hyprpaper
exec_always --no-startup-id wl-paste --type text --watch cliphist store
# exec_always --no-startup-id swaymsg seat seat0 cursor set_theme Adwaita 24

# XDG Autostart
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

