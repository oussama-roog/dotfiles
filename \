#!/usr/bin/env bash

# List your AI models and their URLs
declare -A models
models["ChatGPT"]="https://chatgpt.com/?temporary-chat=true"

# Generate the selection menu
selection=$(printf "%s\n" "${!models[@]}" | rofi -dmenu -theme "$HOME/.config/rofi/launcher/style-4.rasi" -p "Select AI Model")

if [[ -n "$selection" ]]; then
  url="${models[$selection]}"
  # Open Firefox in a new window with only one tab, discarding old session
  firefox --new-instance --private-window "$url"
fi
